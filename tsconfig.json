{
  "compilerOptions": {
    "jsx": "react-jsx", // or "react" if you prefer
    "target": "es2025",
    "module": "node20",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./build",
    "rootDir": "./src",
    "types": [
      "bun"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}