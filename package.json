{
  "name": "potato",
  "version": "0.1.0",
  "bin": {
    "potato": "./bin/potato.js"
  },
  "scripts": {
    "dev": "bun src/index.tsx",
    "link:global": "npm link",
    "unlink:global": "npm unlink -g potato",
    "build:windows": "bun build ./src/index.tsx --compile --outfile potato.exe --target bun-windows-x64 --minify",
    "build:linux": "bun build ./src/index.tsx --compile --outfile potato --target bun-linux-x64 --minify",
    "build:mac": "bun build ./src/index.tsx --compile --outfile potato --target bun-darwin-arm64 --minify"
  },
  "dependencies": {
    "@huggingface/hub": "^2.13.2",
    "@huggingface/transformers": "^4.2.0",
    "@langchain/core": "^1.2.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.3.0",
    "@langchain/openai": "^1.5.1",
    "cheerio": "^1.2.0",
    "deepagents": "^1.10.5",
    "execa": "^9.6.1",
    "ink": "^7.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-prompt": "^0.4.0",
    "ink-scroll-view": "^0.3.7",
    "ink-select-input": "^6.2.0",
    "ink-spawn": "^0.1.4",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "langchain": "^1.5.0",
    "marked": "^18.0.5",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.7",
    "skills": "^1.5.13",
    "supermemory": "^4.24.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "react-devtools-core": "^7.0.1"
  }
}